# ==========================================================
# LLM PROVIDERS
# ==========================================================

# Groq
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.7

# Google Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash


# ==========================================================
# SOCIAL MEDIA API KEYS
# ==========================================================

# Twitter / X API Keys (Tweepy)
TWITTER_API_KEY=YOUR_TWITTER_API_KEY
TWITTER_API_SECRET=YOUR_TWITTER_API_SECRET
TWITTER_ACCESS_TOKEN=YOUR_TWITTER_ACCESS_TOKEN
TWITTER_ACCESS_SECRET=YOUR_TWITTER_ACCESS_SECRET

# Reddit Trends (Optional)
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET
REDDIT_USER_AGENT=AI_Marketing_Optimizer/1.0


# ==========================================================
# GOOGLE SHEETS (Metrics, Logs, A/B Results)
# ==========================================================

# Your Google Sheet ID from the URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID

# Optional: Path to credentials JSON (if using service account)
GOOGLE_APPLICATION_CREDENTIALS=credentials/service_account.json


# ==========================================================
# SLACK NOTIFICATIONS
# ==========================================================

SLACK_WEBHOOK_URL=YOUR_SLACK_WEBHOOK_URL
SLACK_BOT_TOKEN=OPTIONAL
SLACK_CHANNEL_ID=YOUR_SLACK_CHANNEL_ID


# ==========================================================
# MODEL TRAINING & STORAGE
# ==========================================================

MODEL_DIR=models
METRICS_RETRY_LIMIT=3


# ==========================================================
# A/B TESTING SETTINGS
# ==========================================================

# Hours after posting to evaluate A/B performance
AB_EVALUATION_DELAY_HOURS=6


# ==========================================================
# STREAMLIT SETTINGS
# ==========================================================

STREAMLIT_DEBUG=false


# ==========================================================
# SYSTEM FLAGS
# ==========================================================

ENABLE_TRENDING=true
ENABLE_SENTIMENT=true
ENABLE_SHEETS_LOGGING=true
ENABLE_SLACK_NOTIFICATIONS=true
